# =============================================================================
# Harness Terraform PoC - Git Ignore
# =============================================================================

# Terraform files
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars
*.auto.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
tfplan

# Sensitive outputs
outputs.json

# GCP credentials
*.json
!package.json
!tsconfig.json
!**/examples/*.json

# Harness secrets (should never be committed)
**/secrets/
/tmp/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Local environment files
.env
.env.local
.env.*.local

# Backup files
*.bak
*.backup
